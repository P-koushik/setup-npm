{
  "name": "setup",
  "version": "1.0.0",
  "description": "CLI tool to scaffold fullstack projects",
  "bin": {
    "setup": "./dist/index.js"
  },
  "main": "dist/index.js",
  "type": "module",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/bin/index.ts --format esm",
    "dev": "tsx src/bin/index.ts",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "prepare": "husky",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "fs-extra": "^11.3.4",
    "inquirer": "^13.4.1",
    "ora": "^9.3.0"
  }
}
